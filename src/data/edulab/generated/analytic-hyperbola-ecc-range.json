          "b": "P",
          "color": "vecA"
        },
        {
          "type": "segment",
          "name": "PF2",
          "a": "F2",
          "b": "P",
          "color": "vecB"
        }
      ],
      "readouts": [
        {
          "id": "c",
          "label": "半焦距 $c=ae$",
          "type": "expr",
          "expr": "e",
          "digits": 2
        },
        {
          "id": "pf2",
          "label": "$|PF_2|$",
          "type": "distance",
          "a": "F2",
          "b": "P"
        },
        {
          "id": "pf1",
          "label": "$|PF_1|$",
          "type": "distance",
          "a": "F1",
