          "badText": "不满足 ✗",
          "highlight": true
        }
      ],
      "answerBand": {
        "min": 1,
        "max": 3,
        "lo": 1,
        "hi": 2,
        "label": "$e\\in(1,\\ 2]$"
      },
      "legend": [
        {
